{
  "name": "q-relation-tui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "backend": "bun run src/backend.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:integration": "bun test src/lib/intelgraph-client.integration.test.ts src/backend.contract.test.ts",
    "test:fixtures": "bun test src/lib/relation.test.ts",
    "test:wlan": "bun test src/lib/wlan-fixture-e2e.test.ts",
    "test:mcp": "bun test/mcp-smoke.ts",
    "test:indirect-scorecard": "bun test/live-indirect-scorecard.ts",
    "test:connectivity": "bun test/test-mcp-connectivity.ts",
    "test:e2e": "bun test/test-tui-e2e.ts",
    "test:comprehensive": "bun run typecheck && bun test && bun run test:connectivity && bun run test:e2e"
  },
  "dependencies": {
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
